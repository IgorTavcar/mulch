{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "assist": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noExplicitAny": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "files": {
    "includes": [
      "**/*",
      "!!**/dist/",
      "!!**/node_modules/",
      "!!**/*.jsonl",
      "!!**/.overstory/",
      "!!**/.seeds/",
      "!!**/.mulch/",
      "!!**/.entire/",
      "!!**/.claude/"
    ]
  }
}
